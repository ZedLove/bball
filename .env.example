# Server
PORT=4000
CORS_ORIGIN=*        # Tighten in production (e.g. https://your-frontend.example.com)

# MLB scheduler
# Set TEAM to a team abbreviation (e.g. TEAM=TOR) to override TEAM_ID.
# TEAM takes precedence if both are set. Valid abbreviations: run the server
# with an invalid value to see the full list.
TEAM_ID=141          # See https://statsapi.mlb.com/api/v1/teams (141 = TOR)
# TEAM=TOR           # Alternative: use abbreviation instead of numeric ID
IDLE_POLL_INTERVAL=60
ACTIVE_POLL_INTERVAL=10
BATTING_POLL_INTERVAL=30
BETWEEN_INNINGS_BUFFER_S=15   # Extra seconds after the API's inningBreakLength before the next poll
MAX_RETRIES=3
RETRY_BACKOFF_MS=500
