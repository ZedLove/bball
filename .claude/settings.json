{
  "hooks": {
    "PostToolUse": [
      {
        "type": "command",
        "command": ".github/hooks/scripts/auto-format.sh",
        "timeout": 60
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": ".github/hooks/scripts/pre-commit-check.sh",
        "timeout": 120
      }
    ]
  }
}
